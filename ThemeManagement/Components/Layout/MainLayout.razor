@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">テーマ稼働予測システム</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2">@context.User.Identity?.Name</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Href="/.auth/logout" Title="ログアウト" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1">メニュー</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="@(IsAgentPage ? "main-content-shell--fullbleed" : null)">
        <MudContainer MaxWidth="@(IsAgentPage ? MaxWidth.False : MaxWidth.ExtraLarge)"
                      Class="@(IsAgentPage ? "app-body-container--fullbleed" : "pt-6")">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private bool IsAgentPage =>
        Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("agent", StringComparison.OrdinalIgnoreCase);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
