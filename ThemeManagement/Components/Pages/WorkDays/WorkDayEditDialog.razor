@inject IWorkDayService WorkDayService
@inject ICapacitySettings CapacitySettings
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText>@(WorkDays.Year)年 @(WorkDays.Month)月</MudText>
            <MudNumericField T="int" @bind-Value="WorkDays.WorkDays" Label="稼働日数（日）" Min="0" Max="31" Required="true" />
            <MudText Typo="Typo.caption">最大開発可能: @(WorkDays.WorkDays * 8m * CapacitySettings.Coefficient) h</MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">キャンセル</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public MonthlyWorkDays WorkDays { get; set; } = new();

    private async Task Submit()
    {
        await WorkDayService.SaveAsync(WorkDays);
        Snackbar.Add("保存しました", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
