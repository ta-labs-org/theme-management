@page "/workdays"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IWorkDayService WorkDayService
@inject IEngineerService EngineerService
@inject IJapaneseBusinessDayService BusinessDayService
@inject ICapacitySettings CapacitySettings
@inject ISnackbar Snackbar

<PageTitle>稼働日管理</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">稼働日管理</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
        <MudNumericField T="int" @bind-Value="_year" Label="年" Min="2020" Max="2100" Style="width:100px" />
        <MudToggleGroup T="int" @bind-Value="_half" SelectionMode="SelectionMode.SingleSelection"
                        Color="Color.Primary" CheckMark="false">
            <MudToggleItem Value="1" Text="上期（4〜9月）" />
            <MudToggleItem Value="2" Text="下期（10〜3月）" />
        </MudToggleGroup>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">表示</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoAwesome"
                   OnClick="AutoFillBusinessDaysAsync">祝休日除き自動計算</MudButton>
        <MudDivider Vertical="true" Class="mx-2" />
        <MudNumericField T="decimal" @bind-Value="_coefficient" Label="稼働係数" Min="0.1m" Max="1.0m" Step="0.05m"
                         Format="F2" Style="width:100px"
                         @onblur="SaveCoefficient" Adornment="Adornment.End" AdornmentText="×" />
        <MudText Typo="Typo.caption" Color="Color.Secondary">最大開発可能 = 稼働日数 × 8h × 係数</MudText>
    </MudStack>
</MudPaper>

@if (_loaded)
{
    <MudText Typo="Typo.h6" Class="mb-1">全体稼働日</MudText>
    <MudText Typo="Typo.caption" Class="mb-2" Color="Color.Secondary">空欄にすると未設定（削除）になります</MudText>
    <div class="workday-table-wrapper mb-6">
        <table class="workday-table">
            <thead>
                <tr>
                    <th class="wd-label-col">項目</th>
                    @foreach (var (y, m) in _months)
                    {
                        <th>@(y)/<br />@(m)月</th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="wd-label-col">稼働日数（日）</td>
                    @foreach (var (y, m) in _months)
                    {
                        var wd = _workDaysMap.GetValueOrDefault((y, m));
                        <td>
                            <input type="number" class="wd-input"
                                   value="@(wd?.WorkDays.ToString() ?? "")"
                                   min="0" max="31"
                                   placeholder="—"
                                   @onchange="async e => await SaveWorkDayAsync(y, m, e.Value?.ToString())" />
                        </td>
                    }
                </tr>
                <tr class="wd-row-calc">
                    <td class="wd-label-col">最大開発可能(h)</td>
                    @foreach (var (y, m) in _months)
                    {
                        var wd = _workDaysMap.GetValueOrDefault((y, m));
                        <td>@(wd != null ? $"{wd.WorkDays * 8m * _coefficient:F0}h" : "—")</td>
                    }
                </tr>
            </tbody>
        </table>
    </div>

    <MudText Typo="Typo.h6" Class="mb-1">エンジニア個別調整</MudText>
    <MudText Typo="Typo.caption" Class="mb-2" Color="Color.Secondary">未入力＝全体稼働日を使用。空欄に戻すと調整削除。プレースホルダーは全体稼働日数。</MudText>
    <div class="workday-table-wrapper mb-4">
        <table class="workday-table">
            <thead>
                <tr>
                    <th class="wd-label-col">エンジニア</th>
                    @foreach (var (y, m) in _months)
                    {
                        <th>@(y)/<br />@(m)月</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var eng in _engineers)
                {
                    <tr>
                        <td class="wd-label-col wd-eng-name">@eng.Name</td>
                        @foreach (var (y, m) in _months)
                        {
                            var adj = _adjustmentsMap.GetValueOrDefault((eng.Id, y, m));
                            var baseWd = _workDaysMap.GetValueOrDefault((y, m));
                            <td class="@(adj != null ? "wd-cell-adjusted" : "")">
                                <input type="number" class="wd-input"
                                       value="@(adj?.WorkDays.ToString() ?? baseWd?.WorkDays.ToString() ?? "")"
                                       min="0" max="31"
                                       @onchange="async e => await SaveAdjustmentAsync(eng.Id, y, m, e.Value?.ToString(), baseWd?.WorkDays)" />
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _year = DateTime.Now.Month >= 4 ? DateTime.Now.Year : DateTime.Now.Year - 1;
    private int _half = DateTime.Now.Month is >= 4 and <= 9 ? 1 : 2;
    private bool _loaded;
    private decimal _coefficient;

    private List<(int Year, int Month)> _months = [];
    private Dictionary<(int Year, int Month), MonthlyWorkDays> _workDaysMap = new();
    private Dictionary<(int EngineerId, int Year, int Month), EngineerMonthlyAdjustment> _adjustmentsMap = new();
    private List<Engineer> _engineers = [];

    protected override async Task OnInitializedAsync()
    {
        _coefficient = CapacitySettings.Coefficient;
        _engineers = (await EngineerService.GetAllAsync()).Where(e => e.IsActive).ToList();
        await LoadAsync();
    }

    private List<(int Year, int Month)> BuildMonths() =>
        _half == 1
            ? Enumerable.Range(4, 6).Select(m => (_year, m)).ToList()
            : new List<(int, int)>
            {
                (_year, 10), (_year, 11), (_year, 12),
                (_year + 1, 1), (_year + 1, 2), (_year + 1, 3)
            };

    private async Task LoadAsync()
    {
        _months = BuildMonths();

        var workDaysList = await WorkDayService.GetByPeriodAsync(_months);
        _workDaysMap = workDaysList.ToDictionary(w => (w.Year, w.Month));

        var adjList = await WorkDayService.GetAdjustmentsForPeriodAsync(_months);
        _adjustmentsMap = adjList.ToDictionary(a => (a.EngineerId, a.Year, a.Month));

        _loaded = true;
    }

    private void SaveCoefficient()
    {
        _coefficient = Math.Clamp(_coefficient, 0.1m, 1.0m);
        CapacitySettings.Coefficient = _coefficient;
        Snackbar.Add($"稼働係数を {_coefficient:F2} に変更しました", Severity.Success);
        StateHasChanged();
    }

    private async Task AutoFillBusinessDaysAsync()
    {
        int saved = 0;
        foreach (var (y, m) in _months)
        {
            var days = BusinessDayService.GetBusinessDays(y, m);
            var wd = _workDaysMap.GetValueOrDefault((y, m)) ?? new MonthlyWorkDays { Year = y, Month = m };
            if (wd.WorkDays == days) continue; // 既に同じ値なら保存不要
            wd.WorkDays = days;
            await WorkDayService.SaveAsync(wd);
            var saved_ = await WorkDayService.GetByYearMonthAsync(y, m);
            if (saved_ != null) _workDaysMap[(y, m)] = saved_;
            saved++;
        }
        Snackbar.Add(saved > 0 ? $"{saved}ヶ月分の稼働日を自動計算でセットしました" : "変更なし（既に同じ値です）", Severity.Success);
        StateHasChanged();
    }

    private async Task SaveWorkDayAsync(int year, int month, string? valueStr)
    {
        if (string.IsNullOrWhiteSpace(valueStr) || !int.TryParse(valueStr, out var days))
        {
            var existing = _workDaysMap.GetValueOrDefault((year, month));
            if (existing != null)
            {
                await WorkDayService.DeleteAsync(existing.Id);
                _workDaysMap.Remove((year, month));
                Snackbar.Add($"{year}/{month} 稼働日を削除しました", Severity.Info);
                StateHasChanged();
            }
            return;
        }

        var wd = _workDaysMap.GetValueOrDefault((year, month)) ?? new MonthlyWorkDays { Year = year, Month = month };
        wd.WorkDays = days;
        await WorkDayService.SaveAsync(wd);
        var saved = await WorkDayService.GetByYearMonthAsync(year, month);
        if (saved != null) _workDaysMap[(year, month)] = saved;
        Snackbar.Add($"{year}/{month} 稼働日を保存しました", Severity.Success);
        StateHasChanged();
    }

    private async Task SaveAdjustmentAsync(int engId, int year, int month, string? valueStr, int? baseWorkDays = null)
    {
        if (string.IsNullOrWhiteSpace(valueStr) || !int.TryParse(valueStr, out var days))
        {
            var existing = _adjustmentsMap.GetValueOrDefault((engId, year, month));
            if (existing != null)
            {
                await WorkDayService.DeleteAdjustmentAsync(existing.Id);
                _adjustmentsMap.Remove((engId, year, month));
                Snackbar.Add("個別調整を削除しました", Severity.Info);
                StateHasChanged();
            }
            return;
        }

        // ベース稼働日数と同じ値なら調整不要として削除
        if (days == baseWorkDays)
        {
            var existing = _adjustmentsMap.GetValueOrDefault((engId, year, month));
            if (existing != null)
            {
                await WorkDayService.DeleteAdjustmentAsync(existing.Id);
                _adjustmentsMap.Remove((engId, year, month));
                Snackbar.Add("ベース稼働日数と同じため調整を削除しました", Severity.Info);
                StateHasChanged();
            }
            return;
        }

        var adj = _adjustmentsMap.GetValueOrDefault((engId, year, month))
            ?? new EngineerMonthlyAdjustment { EngineerId = engId, Year = year, Month = month };
        adj.WorkDays = days;
        await WorkDayService.SaveAdjustmentAsync(adj);
        var saved = await WorkDayService.GetAdjustmentAsync(engId, year, month);
        if (saved != null) _adjustmentsMap[(engId, year, month)] = saved;
        Snackbar.Add("個別調整を保存しました", Severity.Success);
        StateHasChanged();
    }
}
