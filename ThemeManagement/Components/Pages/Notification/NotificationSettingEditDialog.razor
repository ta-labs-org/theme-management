@inject INotificationService NotificationService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Setting.Email"
                          Label="メールアドレス"
                          InputType="InputType.Email"
                          Required="true"
                          RequiredError="メールアドレスを入力してください"
                          Immediate="true" />

            <MudSelect T="string" @bind-Value="Setting.Frequency" Label="通知頻度">
                <MudSelectItem Value="@("Realtime")">リアルタイム（稼働保存時）</MudSelectItem>
                <MudSelectItem Value="@("Daily")">日次（毎日1回）</MudSelectItem>
                <MudSelectItem Value="@("Weekly")">週次（7日ごと）</MudSelectItem>
            </MudSelect>

            <MudSwitch @bind-Value="Setting.IsActive" Label="有効" Color="Color.Primary" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">キャンセル</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public NotificationSetting Setting { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Setting.Email))
        {
            Snackbar.Add("メールアドレスを入力してください", Severity.Warning);
            return;
        }

        try
        {
            await NotificationService.SaveAsync(Setting);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存エラー: {ex.Message}", Severity.Error);
        }
    }
}
