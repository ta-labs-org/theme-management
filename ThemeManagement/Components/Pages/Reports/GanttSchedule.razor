@page "/report/gantt"
@rendermode InteractiveServer
@using ThemeManagement.Data
@using ThemeManagement.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<PageTitle>ガントチャート</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">テーマ スケジュール (ガントチャート)</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudNumericField T="int" @bind-Value="_displayYear" Label="基準年" Min="2020" Max="2099" Style="width:100px" />
        <MudNumericField T="int" @bind-Value="_displayMonths" Label="表示月数" Min="3" Max="24" Style="width:100px" />
        <MudCheckBox T="bool" @bind-Value="_showAll" Label="完了・中止も含める" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadDataAsync">更新</MudButton>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else if (_themes.Count == 0)
{
    <MudAlert Severity="Severity.Info">表示できるテーマがありません</MudAlert>
}
else
{
    <MudPaper Elevation="2" Style="overflow-x:auto;">
        <table class="gantt-table">
            <thead>
                <tr>
                    <th class="gantt-name-col">テーマ名</th>
                    <th class="gantt-type-col">受注区分</th>
                    @foreach (var (year, month) in _periodMonths)
                    {
                        <th class="gantt-month-col @(year == DateTime.Today.Year && month == DateTime.Today.Month ? "gantt-current-month" : "")">
                            @year/@month:D2
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var theme in _themes)
                {
                    <tr>
                        <td class="gantt-name-col">
                            <MudTooltip Text="@($"受注:{theme.OrderDate:yyyy/MM/dd} 完了予定:{theme.EstimatedCompletionDate:yyyy/MM/dd}")">
                                <a href="/themes/@theme.Id/allocation">@theme.Name</a>
                            </MudTooltip>
                        </td>
                        <td class="gantt-type-col" style="font-size:0.82rem;color:#666">@theme.OrderType</td>
                        @foreach (var (year, month) in _periodMonths)
                        {
                            var cell = GetCellInfo(theme, year, month);
                            <td class="gantt-cell @cell.CssClass">
                                @if (!string.IsNullOrEmpty(cell.Label))
                                {
                                    <span>@cell.Label</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </MudPaper>

    <MudStack Row="true" Spacing="3" Class="mt-3">
        <MudChip T="string" Style="background:#1565c0;color:white" Size="Size.Small">受注・進行中</MudChip>
        <MudChip T="string" Style="background:#81c784;color:white" Size="Size.Small">今月</MudChip>
        <MudChip T="string" Style="background:#ffb300;color:white" Size="Size.Small">完了月</MudChip>
        <MudChip T="string" Style="background:#ef9a9a;color:#b71c1c" Size="Size.Small">期限超過</MudChip>
        <MudChip T="string" Style="background:#e0e0e0;color:#666" Size="Size.Small">完了済み</MudChip>
    </MudStack>
}

<style>
    .gantt-table { border-collapse: collapse; min-width: 100%; font-size: 0.85rem; }
    .gantt-table th, .gantt-table td { border: 1px solid #e0e0e0; padding: 4px 6px; white-space: nowrap; }
    .gantt-table thead th { background: #f5f5f5; font-weight: 600; text-align: center; }
    .gantt-name-col { min-width: 130px; text-align: left; position: sticky; left: 0; background: white; z-index: 1; }
    .gantt-type-col { min-width: 70px; text-align: left; position: sticky; left: 130px; background: white; z-index: 1; }
    .gantt-month-col { min-width: 55px; text-align: center; }
    .gantt-current-month { background: #e3f2fd !important; font-weight: 700; }
    .gantt-cell { text-align: center; }
    .gantt-active { background: #1565c0; color: white; }
    .gantt-today { background: #81c784; color: white; }
    .gantt-deadline { background: #ffb300; color: white; font-weight: 700; }
    .gantt-overdue { background: #ef9a9a; color: #b71c1c; }
    .gantt-completed { background: #e0e0e0; color: #9e9e9e; }
    .gantt-before { background: transparent; }
    .gantt-after { background: transparent; }
</style>

@code {
    private int _displayYear = DateTime.Today.Year;
    private int _displayMonths = 12;
    private bool _showAll = false;
    private bool _loading = false;

    private List<Theme> _themes = [];
    private List<(int Year, int Month)> _periodMonths = [];

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            // 基準年の4月から指定月数分
            var startDate = new DateTime(_displayYear, 4, 1);
            _periodMonths = Enumerable.Range(0, _displayMonths)
                .Select(i => startDate.AddMonths(i))
                .Select(d => (d.Year, d.Month))
                .ToList();

            _themes = await Db.Themes.AsNoTracking()
                .Where(t => _showAll || ThemeStatus.ActiveStatuses.Contains(t.Status))
                .OrderBy(t => t.OrderDate)
                .ToListAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private (string CssClass, string Label) GetCellInfo(Theme theme, int year, int month)
    {
        var cellDate = new DateOnly(year, month, 1);
        var orderMonth = new DateOnly(theme.OrderDate.Year, theme.OrderDate.Month, 1);
        var endMonth = new DateOnly(theme.EstimatedCompletionDate.Year, theme.EstimatedCompletionDate.Month, 1);
        var today = DateOnly.FromDateTime(DateTime.Today);
        var todayMonth = new DateOnly(today.Year, today.Month, 1);
        bool isCompleted = theme.Status == ThemeStatus.Completed || theme.Status == ThemeStatus.Cancelled || theme.Status == ThemeStatus.Lost;

        if (cellDate < orderMonth || cellDate > endMonth)
            return ("gantt-before", "");

        if (isCompleted)
            return ("gantt-completed", "");

        if (cellDate == endMonth)
        {
            if (endMonth < todayMonth)
                return ("gantt-overdue", "期限超過");
            return ("gantt-deadline", "〆");
        }
        if (cellDate == todayMonth)
            return ("gantt-today", "●");

        return ("gantt-active", "");
    }
}
