@inject IEngineerService EngineerService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Engineer.Name" Label="エンジニア名" Required="true" Immediate="true" />
            <MudSelect T="int" @bind-Value="Engineer.GradeId" Label="等級" Required="true">
                @foreach (var g in Grades)
                {
                    <MudSelectItem T="int" Value="@g.Id">@g.Name（売価 @g.UnitSalePrice.ToString("N0")円/h）</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">キャンセル</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Engineer Engineer { get; set; } = new();
    [Parameter] public List<Grade> Grades { get; set; } = [];

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(Engineer.Name))
        {
            Snackbar.Add("エンジニア名を入力してください", Severity.Warning);
            return;
        }
        if (Engineer.GradeId == 0)
        {
            Snackbar.Add("等級を選択してください", Severity.Warning);
            return;
        }
        await EngineerService.SaveAsync(Engineer);
        Snackbar.Add("保存しました", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
