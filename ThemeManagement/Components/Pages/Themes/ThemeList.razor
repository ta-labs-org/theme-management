@page "/themes"
@rendermode InteractiveServer
@inject IThemeService ThemeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>テーマ・案件一覧</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">テーマ・案件一覧</MudText>

<MudStack Row="true" Spacing="3" Class="mb-4" AlignItems="AlignItems.Center">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAddDialog">新規登録</MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.UploadFile"
               OnClick="OpenCsvImportDialog">CSVインポート</MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.FileDownload"
               OnClick="ExportCsvAsync">CSVエクスポート</MudButton>
    <MudCheckBox T="bool" Value="_showAll" ValueChanged="@(async v => { _showAll = v; await LoadAsync(); })" Label="完了・中止も表示" />
</MudStack>

@if (_allTags.Count > 0)
{
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-3" Style="flex-wrap:wrap">
        <MudText Typo="Typo.body2" Class="mr-1">タグ絞り込み:</MudText>
        <MudChip T="string" Size="Size.Small"
                 Color="@(_filterTag == null ? Color.Primary : Color.Default)"
                 Variant="@(_filterTag == null ? Variant.Filled : Variant.Outlined)"
                 OnClick="@(() => _filterTag = null)">すべて</MudChip>
        @foreach (var tag in _allTags)
        {
            var t = tag;
            <MudChip T="string" Size="Size.Small"
                     Color="@(_filterTag == t ? Color.Primary : Color.Default)"
                     Variant="@(_filterTag == t ? Variant.Filled : Variant.Outlined)"
                     OnClick="@(() => _filterTag = (_filterTag == t ? null : t))">@t</MudChip>
        }
    </MudStack>
}

<MudTable Items="_themes" Dense="true" Hover="true" Elevation="2"
          Filter="FilterFunc" SortLabel="ソート">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="_sortByThemeNo">テーマNo</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="_sortByName">テーマ名</MudTableSortLabel></MudTh>
        <MudTh>受注区分</MudTh>
        <MudTh>受注日</MudTh>
        <MudTh>完了予定日</MudTh>
        <MudTh Style="text-align:right">受注金額(円)</MudTh>
        <MudTh>状態</MudTh>
        <MudTh>タグ</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ThemeNo</MudTd>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.OrderType</MudTd>
        <MudTd>@context.OrderDate.ToString("yyyy/MM/dd")</MudTd>
        <MudTd>@context.EstimatedCompletionDate.ToString("yyyy/MM/dd")</MudTd>
        <MudTd Style="text-align:right">@context.OrderAmount.ToString("N0")</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">
                @StatusLabel(context.Status)
            </MudChip>
        </MudTd>
        <MudTd>
            @foreach (var tag in context.GetTagList())
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                         OnClick="@(() => _filterTag = tag)" Style="cursor:pointer">@tag</MudChip>
            }
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => OpenEditDialog(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.BarChart" Size="Size.Small" Color="Color.Info"
                           Href="@($"/themes/{context.Id}/allocation")" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText>テーマが登録されていません</MudText></NoRecordsContent>
</MudTable>

@code {
    private static readonly Func<Theme, object> _sortByThemeNo = x => x.ThemeNo;
    private static readonly Func<Theme, object> _sortByName = x => x.Name;

    private List<Theme> _themes = [];
    private bool _showAll = false;
    private string? _filterTag = null;
    private List<string> _allTags = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _themes = await ThemeService.GetAllAsync(!_showAll);
        _allTags = _themes
            .SelectMany(t => t.GetTagList())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order()
            .ToList();
        if (_filterTag != null && !_allTags.Contains(_filterTag, StringComparer.OrdinalIgnoreCase))
            _filterTag = null;
    }

    private bool FilterFunc(Theme t) =>
        _filterTag == null || t.GetTagList().Contains(_filterTag, StringComparer.OrdinalIgnoreCase);

    private async Task OpenCsvImportDialog()
    {
        var dialog = await DialogService.ShowAsync<ThemeCsvImportDialog>("CSVインポート");
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task OpenAddDialog()
    {
        var theme = new Theme
        {
            OrderDate = DateOnly.FromDateTime(DateTime.Today),
            EstimatedCompletionDate = DateOnly.FromDateTime(DateTime.Today.AddMonths(3)),
            Status = "Active"
        };
        var parameters = new DialogParameters<ThemeEditDialog> { { x => x.Theme, theme } };
        var dialog = await DialogService.ShowAsync<ThemeEditDialog>("テーマ登録", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task OpenEditDialog(Theme theme)
    {
        var copy = new Theme
        {
            Id = theme.Id, ThemeNo = theme.ThemeNo, Name = theme.Name, OrderType = theme.OrderType,
            OrderDate = theme.OrderDate,
            EstimatedCompletionDate = theme.EstimatedCompletionDate,
            ActualCompletionDate = theme.ActualCompletionDate,
            OrderAmount = theme.OrderAmount, Status = theme.Status,
            Tags = theme.Tags
        };
        var parameters = new DialogParameters<ThemeEditDialog> { { x => x.Theme, copy } };
        var dialog = await DialogService.ShowAsync<ThemeEditDialog>("テーマ編集", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private static Color StatusColor(string status) => status switch
    {
        "Quoting" => Color.Warning,
        "Confirmed" => Color.Tertiary,
        "Active" => Color.Success,
        "OnHold" => Color.Dark,
        "Completed" => Color.Info,
        "Lost" => Color.Error,
        "Cancelled" => Color.Default,
        _ => Color.Default
    };

    private static string StatusLabel(string status) => status switch
    {
        "Quoting" => "見積中",
        "Confirmed" => "受注確定",
        "Active" => "進行中",
        "OnHold" => "一時停止",
        "Completed" => "完了",
        "Lost" => "失注",
        "Cancelled" => "中止",
        _ => status
    };

    private static string CsvField(string? value)
    {
        var escaped = (value ?? string.Empty).Replace("\"", "\"\"");
        return $"\"{escaped}\"";
    }

    private async Task ExportCsvAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine(string.Join(",",
            CsvField("テーマNo"),
            CsvField("テーマ名"),
            CsvField("受注区分"),
            CsvField("受注日"),
            CsvField("完了予定日"),
            CsvField("受注金額"),
            CsvField("状態")));
        foreach (var t in _themes)
        {
            sb.AppendLine(string.Join(",",
                CsvField(t.ThemeNo),
                CsvField(t.Name),
                CsvField(t.OrderType),
                CsvField($"{t.OrderDate:yyyy/MM/dd}"),
                CsvField($"{t.EstimatedCompletionDate:yyyy/MM/dd}"),
                CsvField($"{t.OrderAmount}"),
                CsvField(StatusLabel(t.Status))));
        }
        var filename = $"themes_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("downloadCsv", filename, sb.ToString());
    }
}
